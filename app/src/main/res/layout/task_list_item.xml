<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_marginStart="8dp"
    android:layout_marginTop="4dp"
    android:layout_marginEnd="8dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="4dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:id="@+id/layout_item_task"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/material_dynamic_primary80"
        android:orientation="horizontal"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/layout_item_task_details"
            android:layout_width="0dp"
            android:orientation="vertical"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tv_item_task_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Example user"/>

            <TextView
                android:id="@+id/tv_item_task_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="status"/>


            <TextView
                android:id="@+id/tv_item_local_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Local status"/>


        </LinearLayout>

        <CheckBox
            android:id="@+id/checkbox_status"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"/>


    </LinearLayout>

</androidx.cardview.widget.CardView>